@model GESTIONES.Models.Loan

@{
    ViewData["Title"] = "Detalle del Préstamo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-semibold mb-0">Detalle del <span class="text-primary">Préstamo</span></h1>
    <a asp-action="Index" asp-controller="Loan" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<!-- Card detalle -->
<div class="card shadow-sm" style="max-width: 640px;">
    <div class="card-body p-4">

        <!-- Estado badge -->
        <div class="mb-4">
            @if (Model.estado == "Activo")
            {
                <span class="badge bg-danger fs-6">Activo</span>
            }
            else
            {
                <span class="badge bg-success fs-6">Devuelto</span>
            }
        </div>

        <!-- Info del préstamo -->
        <table class="table table-borderless mb-0">
            <tbody>
                <tr>
                    <td class="text-muted fw-medium" style="width:180px;">ID</td>
                    <td><strong>#@Model.Id</strong></td>
                </tr>
                <tr>
                    <td class="text-muted fw-medium">Usuario</td>
                    <td>@(Model.User != null ? Model.User.Username + " " + Model.User.lastname : "—")</td>
                </tr>
                <tr>
                    <td class="text-muted fw-medium">Zona deportiva</td>
                    <td>@(Model.Deporte != null ? Model.Deporte.tipo_espacio : "—")</td>
                </tr>
                <tr>
                    <td class="text-muted fw-medium">Autor</td>
                    <td>@(Model.Deporte != null ? Model.Deporte.Author : "—")</td>
                </tr>
                <tr>
                    <td class="text-muted fw-medium">Stock restante</td>
                    <td>@(Model.Deporte != null ? Model.Deporte.Stock.ToString() : "—")</td>
                </tr>
                <tr>
                    <td class="text-muted fw-medium">Fecha inicio</td>
                    <td>@Model.StartDate.ToString("dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <td class="text-muted fw-medium">Fecha devolución</td>
                    <td>@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("dd/MM/yyyy") : "—")</td>
                </tr>
            </tbody>
        </table>

        <!-- Acciones -->
        <div class="d-flex gap-2 mt-4 pt-3 border-top">
            @if (Model.estado == "Activo")
            {
                <form asp-action="Return" asp-controller="Loan" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success"
                            onclick="return confirm('¿Marcar este préstamo como devuelto?')">
                        <i class="bi bi-check-lg me-1"></i> Marcar como devuelto
                    </button>
                </form>
            }
            <form asp-action="Destroy" asp-controller="Loan" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger"
                        onclick="return confirm('¿Eliminar este préstamo?')">
                    <i class="bi bi-trash me-1"></i> Eliminar
                </button>
            </form>
        </div>

    </div>
</div>