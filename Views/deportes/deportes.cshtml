@model IEnumerable<GESTIONES.Models.deporte>

@{
    ViewData["Title"] = "Zonas Deportivas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-semibold mb-0">Catálogo de <span class="text-primary">Zonas Deportivas</span></h1>
    <a asp-action="CreaResult" asp-controller="deportes" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Agregar zona
    </a>
</div>

<!-- Alerta TempData -->
@if (TempData["message"] != null)
{
    <div class="alert alert-success d-flex align-items-center mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["message"]
    </div>
}

<!-- Tabla -->
<div class="card shadow-sm">
    <div class="card-body p-0">

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-person-workspace fs-1 mb-3 d-block"></i>
                <p>No hay zonas registradas aún.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Tipo de espacio</th>
                            <th>Autor</th>
                            <th>Género</th>
                            <th>Cantidad</th>
                            <th>Stock</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var deporte in Model)
                        {
                            <tr>
                                <td><strong>#@deporte.Id</strong></td>
                                <td>@deporte.tipo_espacio</td>
                                <td>@deporte.Author</td>
                                <td><span class="badge bg-secondary">@deporte.genero</span></td>
                                <td>@deporte.Quantity</td>
                                <td>
                                    @if (deporte.Stock > 5)
                                    {
                                        <span class="badge bg-success">@deporte.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@deporte.Stock</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <a asp-action="Show" asp-controller="deportes" asp-route-id="@deporte.Id"
                                           class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye"></i> Detalles
                                        </a>
                                        <a asp-action="Edit" asp-controller="deportes" asp-route-id="@deporte.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Editar
                                        </a>
                                        <form asp-action="Destroy" asp-controller="deportes" asp-route-id="@deporte.Id" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('¿Eliminar \'@deporte.tipo_espacio\'?')">
                                                <i class="bi bi-trash"></i> Eliminar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>