@model GESTIONES.Models.User

@{
    ViewData["Title"] = "Editar Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-semibold mb-0">Editar <span class="text-primary">Usuario</span></h1>
    <a asp-action="index" asp-controller="User" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<!-- Card formulario -->
<div class="card shadow-sm" style="max-width: 640px;">
    <div class="card-body p-4">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Revisa los campos con error antes de continuar.
            </div>
        }

        <form asp-action="Update" asp-controller="User" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Username" class="form-label fw-medium">Nombre</label>
                    <input asp-for="Username" class="form-control" placeholder="Ej: Juan" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="lastname" class="form-label fw-medium">Apellido</label>
                    <input asp-for="lastname" class="form-control" placeholder="Ej: Pérez" />
                    <span asp-validation-for="lastname" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-medium">Correo electrónico</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="Ej: juan@correo.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="number" class="form-label fw-medium">Teléfono</label>
                <input asp-for="number" class="form-control" type="number" placeholder="Ej: 3001234567" />
                <span asp-validation-for="number" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Guardar cambios
                </button>
                <a asp-action="index" asp-controller="User" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>

    </div>
</div>