@model IEnumerable<GESTIONES.Models.Loan>

@{
    ViewData["Title"] = "Gestión de Préstamos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-semibold mb-0">Gestión de <span class="text-primary">Préstamos</span></h1>
    <a asp-action="Create" asp-controller="Loan" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Nuevo préstamo
    </a>
</div>

<!-- Alerta TempData -->
@if (TempData["message"] != null)
{
    <div class="alert alert-success d-flex align-items-center mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["message"]
    </div>
}

<!-- Tabla -->
<div class="card shadow-sm">
    <div class="card-body p-0">

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-arrow-left-right fs-1 mb-3 d-block"></i>
                <p>No hay préstamos registrados aún.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Usuario</th>
                            <th>Deporte</th>
                            <th>Inicio</th>
                            <th>Devolución</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var loan in Model)
                        {
                            <tr>
                                <td><strong>#@loan.Id</strong></td>
                                <td>@(loan.User != null ? loan.User.Username + " " + loan.User.lastname : "—")</td>
                                <td>@(loan.Deporte != null ? loan.Deporte.tipo_espacio : "—")</td>
                                <td>@loan.StartDate.ToString("dd/MM/yyyy")</td>
                                <td>@(loan.EndDate.HasValue ? loan.EndDate.Value.ToString("dd/MM/yyyy") : "—")</td>
                                <td>
                                    @if (loan.estado == "Activo")
                                    {
                                        <span class="badge bg-danger">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Devuelto</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <a asp-action="Show" asp-controller="Loan" asp-route-id="@loan.Id"
                                           class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye"></i> Detalles
                                        </a>
                                        @if (loan.estado == "Activo")
                                        {
                                            <form asp-action="Return" asp-controller="Loan" asp-route-id="@loan.Id" method="post" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-success"
                                                        onclick="return confirm('¿Marcar como devuelto?')">
                                                    <i class="bi bi-check-lg"></i> Devuelto
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Destroy" asp-controller="Loan" asp-route-id="@loan.Id" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('¿Eliminar este préstamo?')">
                                                <i class="bi bi-trash"></i> Eliminar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>