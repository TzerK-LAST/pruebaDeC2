@model GESTIONES.Models.Loan

@{
    ViewData["Title"] = "Nuevo Préstamo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var users = ViewBag.Users as IEnumerable<GESTIONES.Models.User>;
    var books = ViewBag.Books as IEnumerable<GESTIONES.Models.deporte>;
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-semibold mb-0">Nuevo <span class="text-primary">Préstamo</span></h1>
    <a asp-action="Index" asp-controller="Loan" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<!-- Card formulario -->
<div class="card shadow-sm" style="max-width: 640px;">
    <div class="card-body p-4">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Revisa los campos con error antes de continuar.
            </div>
        }

        <form asp-action="Store" asp-controller="Loan" method="post">
            @Html.AntiForgeryToken()

            <!-- Usuario -->
            <div class="mb-3">
                <label asp-for="UserId" class="form-label fw-medium">Usuario</label>
                <select asp-for="UserId" class="form-select">
                    <option value="">— Selecciona un usuario —</option>
                    @if (users != null)
                    {
                        @foreach (var u in users)
                        {
                            <option value="@u.Id">@u.Username @u.lastname</option>
                        }
                    }
                </select>
                <span asp-validation-for="UserId" class="text-danger small"></span>
            </div>

            <!-- Zona deportiva -->
            <div class="mb-4">
                <label asp-for="deporteid" class="form-label fw-medium">Zona deportiva</label>
                <select asp-for="deporteid" class="form-select">
                    <option value="">— Selecciona una zona —</option>
                    @if (books != null)
                    {
                        @foreach (var b in books)
                        {
                            @if (b.Stock <= 0)
                            {
                                <option value="@b.Id" disabled>@b.Author — Sin stock</option>
                            }
                            else
                            {
                                <option value="@b.Id">@b.Author — Stock: @b.Stock</option>
                            }
                        }
                    }
                </select>
                <span asp-validation-for="deporteid" class="text-danger small"></span>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Registrar préstamo
                </button>
                <a asp-action="Index" asp-controller="Loan" class="btn btn-outline-secondary">
                    Cancelar
                </a>
            </div>

        </form>
    </div>
</div>
